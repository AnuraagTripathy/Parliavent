# Database (required for saved debates)
# Prisma CLI reads .env.local via npm run db:migrate
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/parliavent?schema=public"
# If your password contains @ or #, URL-encode it (e.g. @ becomes %40)

# Existing API keys (see .env.local)
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# USE_MOCK_JUDGE=false
# TAVILY_API_KEY=

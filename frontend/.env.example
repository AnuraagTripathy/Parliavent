# Database (required for saved debates)
# Prisma CLI reads .env.local via npm run db:migrate
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/parliavent?schema=public"
# If your password contains @ or #, URL-encode it (e.g. @ becomes %40)

# Hexclave auth (cloud — https://app.hexclave.com)
NEXT_PUBLIC_HEXCLAVE_PROJECT_ID=dd812125-ddba-468b-b08f-d1226e6137dd
NEXT_PUBLIC_HEXCLAVE_API_URL=https://api.stack-auth.com
HEXCLAVE_PROJECT_ID=dd812125-ddba-468b-b08f-d1226e6137dd
HEXCLAVE_API_URL=https://api.stack-auth.com
# HEXCLAVE_SECRET_SERVER_KEY=   # from Project Keys in the dashboard (server-only, never commit)

# Judge — MOCK by default; set to "false" to use the real Groq judge
# USE_MOCK_JUDGE=false

# Existing API keys (see .env.local)
# GROQ_API_KEY=
# Judge model (free tier limits vary by model — see console.groq.com/settings/limits)
# GROQ_MODEL=llama-3.3-70b-versatile
# Judge + evidence use separate Groq models (free-tier rate limits are per model):
# GROQ_JUDGE_MODEL=llama-3.1-8b-instant
# GROQ_VERIFIER_MODEL=llama-3.3-70b-versatile
# SEED_JUDGE_PACE_MS=18000
# SEED_EVIDENCE_PACE_MS=22000
# SEED_MAX_EVIDENCE_PER_POST=2
# TAVILY_API_KEY=

# Async evidence jobs (optional — omit to use sync /api/evidence/search)
# FASTAPI_EVIDENCE_URL=http://localhost:8000
# Long random string (e.g. `openssl rand -hex 32`); must match the FastAPI
# service's env. The literal placeholder below is rejected by the server.
# EVIDENCE_INTERNAL_SECRET=change-me-to-a-long-random-string

# Deployment: see parliavent/docs/DEPLOYMENT.md (Vercel + Render/Neon, free tier)
